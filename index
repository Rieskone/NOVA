<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NOVA | Elite Biohacking Research</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&family=JetBrains+Mono:wght@500;700&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --bg-main: #ffffff;
            --bg-secondary: #f2f2f7;
            --accent-cian: #00e5ff;
            --text-main: #000000;
            --text-secondary: #636366;
            --border: #e5e5ea;
            --dark-btn: #121217;
            --transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Inter', sans-serif; -webkit-font-smoothing: antialiased; }
        body { background-color: var(--bg-main); color: var(--text-main); overflow-x: hidden; scroll-behavior: smooth; }

        /* --- CAPAS AMBIENTALES --- */
        .noise { position: fixed; inset: 0; background: url('https://grainy-gradients.vercel.app/noise.svg'); opacity: 0.03; pointer-events: none; z-index: 9999; }
        .grid-bg { position: fixed; inset: 0; background-image: linear-gradient(var(--border) 1px, transparent 1px), linear-gradient(90deg, var(--border) 1px, transparent 1px); background-size: 60px 60px; z-index: -1; opacity: 0.4; }

        /* --- NAVEGACIÓN --- */
        nav {
            position: fixed; top: 0; width: 100%; height: 80px; padding: 0 6%;
            display: flex; justify-content: space-between; align-items: center;
            background: rgba(255, 255, 255, 0.85); backdrop-filter: blur(20px);
            z-index: 1000; border-bottom: 1px solid var(--border);
        }
        .logo { font-weight: 800; font-size: 1.6rem; letter-spacing: -1.5px; }
        .cart-icon-btn { background: none; border: none; cursor: pointer; position: relative; color: #000; }
        .cart-badge { 
            position: absolute; top: -8px; right: -8px; background: var(--accent-cian); 
            color: #000; font-size: 10px; font-weight: 800; width: 18px; height: 18px; 
            border-radius: 50%; display: flex; align-items: center; justify-content: center;
        }

        /* --- SECCIONES DIAGONALES --- */
        section { padding: 120px 10%; position: relative; }
        .diagonal-hero {
            clip-path: polygon(0 0, 100% 0, 100% 88%, 0 100%);
            background: radial-gradient(circle at top right, #f0faff 0%, #ffffff 60%);
            padding-top: 220px; padding-bottom: 240px; text-align: center;
        }
        .diagonal-science {
            clip-path: polygon(0 6%, 100% 0, 100% 94%, 0 100%);
            background: #fff; border-top: 1px solid var(--border);
            margin-top: -60px; padding-top: 160px;
        }
        .diagonal-shipping {
            clip-path: polygon(0 6%, 100% 0, 100% 100%, 0 100%);
            background: var(--bg-secondary);
            margin-top: -60px; padding: 160px 10%;
        }

        /* --- HERO --- */
        .hero-title { font-size: clamp(3rem, 7vw, 6rem); font-weight: 800; letter-spacing: -4px; line-height: 1; margin-bottom: 10px; }
        .hero-title.accent { color: var(--accent-cian); }
        .hero-subtitle { color: var(--text-secondary); font-size: 1.15rem; max-width: 550px; margin: 30px auto 0; line-height: 1.6; }

        .hero-btns { display: flex; flex-direction: column; gap: 14px; max-width: 380px; margin: 50px auto 0; }
        
        .btn-primary { 
            background: var(--accent-cian); color: #000; border: none; padding: 20px; 
            border-radius: 16px; font-weight: 700; display: flex; align-items: center; 
            justify-content: center; gap: 12px; cursor: pointer; 
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
            font-size: 1rem; box-shadow: 0 10px 20px rgba(0, 229, 255, 0.15);
        }
        /* Efecto Negativo Solicitado */
        .btn-primary:hover { 
            background: #000; color: #fff; transform: translateY(-3px); 
            box-shadow: 0 15px 35px rgba(0, 229, 255, 0.5); 
        }
        .btn-primary svg { transition: transform 0.3s; }
        .btn-primary:hover svg { transform: translateX(5px); }

        .btn-secondary {
            background: #fff; color: #000; border: 1px solid var(--border); padding: 20px;
            border-radius: 16px; font-weight: 700; display: flex; align-items: center; 
            justify-content: center; gap: 12px; cursor: pointer; transition: 0.3s;
        }

        /* --- APPLE CARDS (CIENCIA EXPANDIDA) --- */
        .apple-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 2.5rem; margin-top: 4rem; }
        .apple-card { background: #fff; padding: 4rem 2.5rem; border-radius: 35px; border: 1px solid var(--border); transition: var(--transition); text-align: left; }
        .apple-card:hover { transform: translateY(-10px); border-color: var(--accent-cian); box-shadow: 0 30px 60px rgba(0, 229, 255, 0.12); }
        .apple-card h3 { font-size: 2rem; letter-spacing: -1.5px; margin-bottom: 1.5rem; }
        .apple-card p { color: var(--text-secondary); line-height: 1.7; font-size: 0.95rem; margin-bottom: 15px; }

        /* --- CATÁLOGO --- */
        .search-bar { position: relative; margin: 40px auto; max-width: 600px; }
        .search-bar input { width: 100%; padding: 20px 20px 20px 60px; border-radius: 20px; border: 1px solid var(--border); background: var(--bg-secondary); outline: none; transition: 0.3s; }
        .search-bar input:focus { background: #fff; border-color: var(--accent-cian); }
        .search-bar svg { position: absolute; left: 22px; top: 50%; transform: translateY(-50%); color: var(--text-secondary); }

        .product-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(340px, 1fr)); gap: 40px; margin-top: 60px; }
        .product-card { background: #fff; border-radius: 32px; border: 2px solid var(--border); overflow: hidden; transition: var(--transition); cursor: pointer; }
        .product-card:hover { transform: translateY(-12px); border-color: var(--accent-cian); box-shadow: 0 40px 80px rgba(0, 229, 255, 0.15); }

        .img-container { position: relative; height: 320px; background: #f9f9f9; overflow: hidden; }
        .img-container img { width: 100%; height: 100%; object-fit: cover; transition: 0.8s; }
        .stock-badge { position: absolute; top: 20px; right: 20px; background: var(--accent-cian); color: #000; font-weight: 800; font-size: 11px; padding: 8px 16px; border-radius: 100px; text-transform: uppercase; }

        .product-body { padding: 30px; }
        .product-price { font-size: 1.6rem; font-weight: 800; color: var(--accent-cian); }
        .btn-add-cart { width: 100%; padding: 18px; border-radius: 18px; border: none; background: var(--dark-btn); color: #fff; font-weight: 700; display: flex; align-items: center; justify-content: center; gap: 12px; cursor: pointer; transition: 0.3s; }
        .btn-add-cart:hover { background: var(--accent-cian); color: #000; }

        /* --- SECCIÓN ENVÍOS --- */
        .shipping-content { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 40px; align-items: center; }
        .shipping-item { background: #fff; padding: 30px; border-radius: 24px; border: 1px solid var(--border); display: flex; gap: 20px; align-items: center; }
        .shipping-item svg { color: var(--accent-cian); flex-shrink: 0; }
        .shipping-text h4 { font-weight: 800; font-size: 1.1rem; margin-bottom: 5px; }
        .shipping-text p { color: var(--text-secondary); font-size: 0.85rem; }

        /* --- DISCLAIMER --- */
        .disclaimer { background: rgba(255, 59, 48, 0.05); border: 1px solid rgba(255, 59, 48, 0.15); padding: 30px; border-radius: 24px; color: #ff3b30; font-size: 0.85rem; text-align: center; max-width: 900px; margin: 40px auto; line-height: 1.6; }

        /* --- CARRITO --- */
        #cart-drawer { position: fixed; right: -100%; top: 0; width: 100%; max-width: 500px; height: 100vh; background: #fff; z-index: 2000; padding: 50px; transition: var(--transition); box-shadow: -30px 0 80px rgba(0,0,0,0.08); display: flex; flex-direction: column; }
        #cart-drawer.active { right: 0; }

        .reveal { opacity: 0; transform: translateY(40px); transition: all 1s ease-out; }
        .reveal.active { opacity: 1; transform: translateY(0); }
    </style>
</head>
<body>

    <div class="noise"></div>
    <div class="grid-bg"></div>

    <nav>
        <div class="logo">NOVA</div>
        <div class="nav-icons">
            <button class="cart-icon-btn" onclick="toggleCart()">
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                <span class="cart-badge" id="cart-count">0</span>
            </button>
        </div>
    </nav>

    <main>
        <!-- 1. HERO -->
        <section class="diagonal-hero">
            <div class="tag-investigacion" style="display:inline-flex; align-items:center; gap:8px; background:#f2f2f7; padding:8px 18px; border-radius:100px; font-size:11px; font-weight:700; color:var(--text-secondary); text-transform:uppercase; margin-bottom:20px;">
                <span style="width:6px; height:6px; background:var(--accent-cian); border-radius:50%;"></span> Solo para investigación
            </div>
            
            <h1 class="hero-title">Optimización celular</h1>
            <h1 class="hero-title accent">Biohacking Élite</h1>

            <p class="hero-subtitle">Catálogo privado de compuestos rigurosamente probados para protocolos de investigación avanzada. No se destina su uso humano.</p>
            
            <div class="hero-btns">
                <button class="btn-primary" onclick="document.getElementById('peptidos').scrollIntoView()">
                    Ver Catálogo 
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
                    </svg>
                </button>
                <button class="btn-secondary" onclick="document.getElementById('trazabilidad').scrollIntoView()">Verificar COA</button>
            </div>
        </section>

        <!-- 2. CIENCIA CLARA (MOVIDA ARRIBA Y EXPANDIDA) -->
        <section id="ciencia" class="diagonal-science">
            <div class="reveal">
                <div style="text-align: center; margin-bottom: 40px; color: var(--text-secondary); font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 2px;">
                    ———— Ciencia y Estándares ————
                </div>
                <h2 style="font-size: 3rem; text-align: center; letter-spacing: -2px; margin-bottom: 60px;">Péptidos en ciencia clara</h2>
                
                <div class="apple-grid">
                    <div class="apple-card">
                        <div style="background:rgba(0,229,255,0.1); width:50px; height:50px; border-radius:12px; display:flex; align-items:center; justify-content:center; margin-bottom:25px;">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--accent-cian)" stroke-width="2"><path d="M12 2v20M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                        </div>
                        <h3>¿Qué son los péptidos?</h3>
                        <p>Son cadenas cortas de aminoácidos vinculados por enlaces peptídicos. A diferencia de las proteínas, su menor tamaño molecular les otorga una afinidad selectiva por receptores celulares específicos.</p>
                        <p>Actúan como mensajeros que desencadenan respuestas biológicas precisas, permitiendo el estudio de vías de señalización metabólica de manera aislada y controlada.</p>
                    </div>
                    <div class="apple-card">
                        <div style="background:rgba(0,229,255,0.1); width:50px; height:50px; border-radius:12px; display:flex; align-items:center; justify-content:center; margin-bottom:25px;">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--accent-cian)" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
                        </div>
                        <h3>Pureza HPLC & MS</h3>
                        <p>La integridad estructural es nuestro estándar. Cada lote es verificado mediante Cromatografía Líquida de Alta Resolución (HPLC) y Espectrometría de Masas (MS).</p>
                        <p>Garantizamos una pureza superior al 99.0%, eliminando endotoxinas, metales pesados y residuos de síntesis que podrían interferir en la reproducibilidad de sus resultados de investigación.</p>
                    </div>
                    <div class="apple-card">
                        <div style="background:rgba(0,229,255,0.1); width:50px; height:50px; border-radius:12px; display:flex; align-items:center; justify-content:center; margin-bottom:25px;">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--accent-cian)" stroke-width="2"><path d="M10 2v7.31"/><path d="M14 9.3V2"/><path d="M8.5 2h7"/><path d="M14 9.3a6.5 6.5 0 1 1-4 0"/><path d="M5.52 16h12.96"/></svg>
                        </div>
                        <h3>Investigación R&D</h3>
                        <p>Estos compuestos están destinados exclusivamente al estudio in-vitro e in-vivo en contextos de I+D. Son herramientas críticas para el mapeo de ligandos y receptores.</p>
                        <p>NOVA proporciona la base química necesaria para estudios avanzados sobre autofagia, regeneración tisular, síntesis de proteínas y mecanismos de longevidad celular.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- 3. CATÁLOGO DE INVESTIGACIÓN -->
        <section id="peptidos">
            <div class="reveal">
                <h2 style="font-size: 2.8rem; font-weight: 800; letter-spacing: -2px; text-align: center; margin-bottom: 40px;">Péptidos de Investigación</h2>
                <div class="search-bar">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                    <input type="text" placeholder="Buscar por número CAS o nombre">
                </div>
                <div class="product-grid" id="product-list"></div>
            </div>
        </section>

        <!-- 4. SECCIÓN ENVÍOS (NUEVA) -->
        <section id="shipping" class="diagonal-shipping">
            <div class="reveal">
                <h2 style="font-size: 2.5rem; font-weight: 800; letter-spacing: -1.5px; margin-bottom: 40px;">Logística y Distribución Chile</h2>
                <div class="shipping-content">
                    <div class="shipping-item">
                        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13"/><polyline points="16 8 20 8 23 11 23 16 16 16"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                        <div class="shipping-text">
                            <h4>Envíos a todo el territorio</h4>
                            <p>Cobertura nacional desde Arica a Punta Arenas vía ChileExpress o Starken en modalidad prioritaria.</p>
                        </div>
                    </div>
                    <div class="shipping-item">
                        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/></svg>
                        <div class="shipping-text">
                            <h4>Empaque Discreto y Seguro</h4>
                            <p>Viales protegidos contra impactos y radiación UV para asegurar la estabilidad del compuesto durante el tránsito.</p>
                        </div>
                    </div>
                    <div class="shipping-item">
                        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                        <div class="shipping-text">
                            <h4>Entrega en 24-48h</h4>
                            <p>Procesamiento inmediato de órdenes para asegurar la llegada rápida de sus insumos de laboratorio.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- 5. TRAZABILIDAD COA -->
        <section id="trazabilidad">
            <div class="reveal" style="background:var(--bg-main); padding:5rem; border-radius:50px; border:1px solid var(--border); text-align: center;">
                <h2 style="letter-spacing: -1.5px;">Verificación COA</h2>
                <p style="margin:20px auto 40px; color:var(--text-secondary); max-width: 600px;">Acceda a los informes de pureza química ingresando el código de lote de su vial para asegurar la reproducibilidad de sus experimentos.</p>
                <div style="display:flex; gap:15px; max-width:500px; margin: 0 auto;">
                    <input type="text" placeholder="Código de Lote (Ej: NV-882)" style="flex:1; padding:18px; border-radius:14px; border:1px solid var(--border); outline:none;">
                    <button class="btn-primary" style="width:auto; padding:0 30px;">Verificar</button>
                </div>
            </div>
        </section>

        <footer>
            <div class="disclaimer">
                <strong>ADVERTENCIA LEGAL:</strong> Todos los péptidos de NOVA están destinados exclusivamente a investigación científica y desarrollo de laboratorio. No son aptos para consumo humano, médico o veterinario. NOVA BIOTECH se exime de toda responsabilidad por uso indebido. Al realizar una orden, usted certifica que es un investigador calificado.
            </div>
            <p style="margin-top: 40px; color: var(--text-secondary); font-size: 0.9rem; font-weight: 600; text-align:center;">© 2024 NOVA BIOTECH CHILE | CIENCIA Y RENDIMIENTO</p>
        </footer>
    </main>

    <!-- CARRITO -->
    <div id="cart-drawer">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:40px;">
            <h2 style="font-weight: 800;">Tu Selección</h2>
            <button onclick="toggleCart()" style="background:none; border:none; font-size: 2rem; cursor:pointer;">&times;</button>
        </div>
        <div id="cart-items" style="flex-grow: 1; overflow-y: auto;"></div>
        <div style="border-top: 2px solid var(--border); padding-top: 30px;">
            <div style="display: flex; justify-content: space-between; font-size: 1.8rem; font-weight: 800; margin-bottom: 30px;">
                <span>Total:</span>
                <span id="total-price">$0</span>
            </div>
            <button class="btn-add-cart" onclick="alert('Contacto: pagos@novabiotech.cl')">FINALIZAR PEDIDO</button>
        </div>
    </div>

    <script>
        const products = [
            { id: 1, name: "GHK-Cu", cat: "Péptido de Cobre", price: 45000, img: "https://images.unsplash.com/photo-1582719471384-894fbb16e074?q=80&w=1000", specs: ["Liofilizado • 50mg", "Temp: -20°C"] },
            { id: 2, name: "Retatrutide", cat: "Triple Agonista", price: 185000, img: "https://images.unsplash.com/photo-1532187875605-2fe35877c467?q=80&w=1000", specs: ["Liofilizado • 10mg", "Temp: -20°C"] },
            { id: 3, name: "Tesamorelin", cat: "Señalización GHRH", price: 120000, img: "https://images.unsplash.com/photo-1579165233006-2240ee03137a?q=80&w=1000", specs: ["Liofilizado • 2mg", "Temp: -20°C"] }
        ];

        function renderProducts() {
            const fmt = new Intl.NumberFormat('es-CL', { style: 'currency', currency: 'CLP', maximumFractionDigits: 0 });
            document.getElementById('product-list').innerHTML = products.map(p => `
                <div class="product-card">
                    <div class="img-container">
                        <span class="stock-badge">En Stock</span>
                        <img src="${p.img}">
                    </div>
                    <div class="product-body">
                        <div style="display:flex; justify-content:space-between; align-items:flex-start;">
                            <h3 style="font-weight:800; font-size:1.5rem;">${p.name}</h3>
                            <span class="product-price">${fmt.format(p.price)}</span>
                        </div>
                        <span style="color:#0071e3; font-size:0.95rem; font-weight:600; display:block; margin:5px 0 15px;">${p.cat}</span>
                        <ul style="list-style:none; margin-bottom:25px;">
                            ${p.specs.map(s => `<li style="font-size:0.9rem; color:var(--text-secondary); margin-bottom:8px;">• ${s}</li>`).join('')}
                        </ul>
                        <button class="btn-add-cart" onclick="addToCart(${p.id})">Añadir al carrito</button>
                    </div>
                </div>
            `).join('');
        }

        let cart = [];
        function toggleCart() { document.getElementById('cart-drawer').classList.toggle('active'); }
        function addToCart(id) {
            const p = products.find(x => x.id === id);
            const exists = cart.find(x => x.id === id);
            if(exists) exists.qty++; else cart.push({...p, qty: 1});
            updateCart();
            if(!document.getElementById('cart-drawer').classList.contains('active')) toggleCart();
        }
        function updateCart() {
            const fmt = new Intl.NumberFormat('es-CL', { style: 'currency', currency: 'CLP', maximumFractionDigits: 0 });
            document.getElementById('cart-count').innerText = cart.reduce((a, b) => a + b.qty, 0);
            document.getElementById('cart-items').innerHTML = cart.map(item => `<div style="display:flex; justify-content:space-between; margin-bottom:15px;"><div><strong>${item.name}</strong> x${item.qty}</div><div>${fmt.format(item.price * item.qty)}</div></div>`).join('');
            document.getElementById('total-price').innerText = fmt.format(cart.reduce((a, b) => a + (b.price * b.qty), 0));
        }

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('active'); });
        }, { threshold: 0.1 });

        window.onload = () => {
            renderProducts();
            document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
        };
    </script>
</body>
</html>
